</span></span><span style="display:flex;"><span><span style="color:#f38ba8">func</span> <span style="color:#89b4fa">NewUserDB</span>(conn <span style="color:#89dceb;font-weight:bold">*</span>sqlx.DB) <span style="color:#89dceb;font-weight:bold">*</span>UserDB {
